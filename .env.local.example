#############################
# Payload CMS Configuration #
#############################

# Base URL for your Payload CMS instance (no secrets)
PAYLOAD_API_URL=https://your-cms-domain.com/api

# Demo Payload API key (replace in local .env.local / hosting provider secrets)
PAYLOAD_API_KEY=demo_payload_api_key

################
# Supabase App #
################

# Public Supabase URL used by the app (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co

# Public Supabase anon key used in the browser (use real key only in .env.local / hosting secrets)
NEXT_PUBLIC_SUPABASE_ANON_KEY=demo_supabase_anon_key

# Service role key (NEVER expose to the browser, only set in server env/secrets)
SUPABASE_SERVICE_ROLE_KEY=demo_service_role_key

########################
# RevenueCat & Webhook #
########################

# Public Web Billing API key for RevenueCat Web SDK (client-side)
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY=demo_revenuecat_public_key

# Webhook secret used by the Supabase Edge Function (server-side only)
RC_WEBHOOK_SECRET=demo_revenuecat_webhook_secret

################
# OneSignal    #
################

# OneSignal App ID (public identifier used in the client)
ONESIGNAL_APP_ID=demo-onesignal-app-id

# OneSignal REST API key (server-side secret only)
ONESIGNAL_REST_API_KEY=demo-onesignal-rest-api-key

################
# Test helpers #
################

# Optional overrides for automated tests
TEST_USER_EMAIL=test-paywall@example.com
TEST_USER_PASSWORD=demo-test-password-123!
